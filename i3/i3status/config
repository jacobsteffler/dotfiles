# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
    colors = true
    interval = 1
}

order += "disk /"
order += "ethernet tun0"
order += "ethernet enp0s31f6"
order += "load"
order += "volume master"
order += "tztime local"

disk "/" {
    format = "%avail"
}

ethernet tun0 {
    format_up = "vpn"
    format_down = ""
}

ethernet enp0s31f6 {
    format_up = "E: %ip"
    format_down = "E: down"
}

load {
    format = "%1min"
}

volume master {
    format = "%volume"
    format_muted = "muted"
    device = "pulse"
}

tztime local {
    format = "%A, %B %d, %Y %l:%M:%S %p"
}
